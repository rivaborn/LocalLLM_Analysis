# .env -- Local LLM pipeline configuration
#
# Read automatically by ArchAnalysis/*.ps1 scripts.
# Place this file in the ArchAnalysis/ directory.

# ── Local LLM (Ollama) settings ──
LLM_HOST=192.168.1.126
LLM_PORT=11434
#LLM_MODEL=qwen2.5-coder:14b
LLM_MODEL=devstral-small-2
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=800
LLM_TIMEOUT=120

# ── Codebase ──
PRESET=cnc
CODEBASE_DESC="Command & Conquer Remastered Collection source release (EA/Westwood, open-sourced 2020). Contains the original C++ game logic for Tiberian Dawn (1995) and Red Alert (1996) as shipped in the Remastered Collection DLLs, plus a C# WinForms map editor. Covers game logic, AI, rendering, networking, audio, UI, and Win32 platform layer."

# ── File handling ──
MAX_FILE_LINES=800
SKIP_TRIVIAL=1
MIN_TRIVIAL_LINES=20
CHUNK_THRESHOLD=400

# ── Preset overrides ──
# Add .cs so the CnCTDRAMapEditor (C# WinForms) subsection picks up source files.
# Add bin/obj (C# build output) and Steamworks.NET (third-party Steam API binding) to excludes.
INCLUDE_EXT_REGEX=\.(cpp|h|hpp|c|cc|cxx|inl|inc|cs)$
EXCLUDE_DIRS_REGEX=[/\\](\.git|architecture|Debug|Release|x64|Win32|\.vs|bin|obj|Steamworks\.NET)([/\\]|$)

#Subsections begin
REDALERT
# 530 files at root + 79 in WIN32LIB subdir -- Red Alert (1996) game engine, AI, rendering, networking, audio, UI; Win32 platform layer under WIN32LIB/
TIBERIANDAWN
# 307 files at root + 82 in WIN32LIB subdir -- Tiberian Dawn (1995) game engine, AI, rendering, networking, audio, UI; Win32 platform layer under WIN32LIB/
CnCTDRAMapEditor
# 257 C# files -- WinForms map editor for both TD and RA (Controls, Dialogs, Model, Render, Tools, Utility, Widgets, Steamworks.NET)
#Subsections end
