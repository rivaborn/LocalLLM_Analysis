# .env -- Local LLM pipeline configuration (Analysis-only)
#
# Location: LocalLLM_Analysis/Common/.env
# Read by every PS1 in Analysis/ via the shared module
# (Analysis/<script>.ps1 -> ../Common/llm_common.ps1).

# ── Ollama server endpoint ──
# One-line override: uncomment LLM_ENDPOINT to use a full URL.
# Otherwise LLM_HOST + LLM_PORT are composed into http://HOST:PORT.
#LLM_ENDPOINT=http://192.168.1.126:11434
LLM_HOST=192.168.1.126
LLM_PORT=11434

# ── Models ──
#
# LLM_DEFAULT_MODEL is the universal fallback. Every role-specific key
# below falls back to it when blank or unset — so changing the model
# system-wide = edit LLM_DEFAULT_MODEL and nothing else.
#
# Resolution chain (PowerShell Get-LLMModel):
#   role-specific key  ->  LLM_DEFAULT_MODEL  ->  hardcoded fallback

LLM_DEFAULT_MODEL=qwen3-coder:30b
#LLM_DEFAULT_MODEL=devstral-small-2
#LLM_DEFAULT_MODEL=qwen2.5-coder:14b

# Analysis workers (all Analysis/*_local.ps1 scripts).
# Leave blank to use LLM_DEFAULT_MODEL.
#LLM_MODEL=

# Reserved for an optional reasoning model on synthesis stages
# (arch_overview_local). Leave blank to use LLM_DEFAULT_MODEL.
#LLM_PLANNING_MODEL=gemma4:26b

# ── Thinking mode (reasoning-model support) ──
# Reasoning models emit reasoning in message.thinking separately from
# message.content. LLM_THINK=true puts the model in thinking mode on
# /api/chat; LLM_SAVE_THINKING=true writes reasoning to .thinking.md
# sidecars for audit/debug. Only effective when LLM_NUM_CTX > 0.
LLM_THINK=false
LLM_SAVE_THINKING=false

# ── Context / token / timeout budgets ──
# When LLM_NUM_CTX > 0, Invoke-LocalLLM uses /api/chat with
# options.num_ctx so the model gets the full window on every call.
# When 0 or unset, it falls back to /v1/chat/completions.
LLM_NUM_CTX=32768

# Analysis uses a larger window — arch synthesis + pass 2 read
# many per-file docs at once. Analysis scripts promote this value into
# LLM_NUM_CTX after loading config.
# Tuned for RTX 3090 (24 GB VRAM) + qwen3-coder:30b (Q4_K_M MoE,
# ~3B active). 65536 lands around 22 GB VRAM with KV cache.
LLM_ANALYSIS_NUM_CTX=65536

# Reserved for an optional reasoning model on synthesis stages.
LLM_PLANNING_NUM_CTX=98304
LLM_PLANNING_MAX_TOKENS=65536
LLM_PLANNING_TIMEOUT=1200

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=8192
# 900s leaves headroom for thinking-MoE models. Drop to 300 when running
# a non-thinking coder via LLM_MODEL override.
LLM_TIMEOUT=600

# ── Cross-pipeline integration paths (optional) ──
# Reserved for a future Debug pipeline that consumes Analysis outputs.
# Leave commented out for analysis-only runs.
#ARCHITECTURE_DIR=architecture
#SERENA_CONTEXT_DIR=architecture/.serena_context

# ── Codebase ──
PRESET=cnc
CODEBASE_DESC="Command & Conquer Remastered Collection source release (EA/Westwood, open-sourced 2020). Contains the original C++ game logic for Tiberian Dawn (1995) and Red Alert (1996) as shipped in the Remastered Collection DLLs, plus a C# WinForms map editor. Covers game logic, AI, rendering, networking, audio, UI, and Win32 platform layer."

# ── File handling ──
MAX_FILE_LINES=800
SKIP_TRIVIAL=1
MIN_TRIVIAL_LINES=20
CHUNK_THRESHOLD=400

# ── Preset overrides ──
# Add .cs so the CnCTDRAMapEditor (C# WinForms) subsection picks up source files.
# Add bin/obj (C# build output) and Steamworks.NET (third-party Steam API binding) to excludes.
INCLUDE_EXT_REGEX=\.(cpp|h|hpp|c|cc|cxx|inl|inc|cs)$
EXCLUDE_DIRS_REGEX=[/\\](\.git|architecture|Debug|Release|x64|Win32|\.vs|bin|obj|Steamworks\.NET)([/\\]|$)

#Subsections begin
REDALERT
# 530 files at root + 79 in WIN32LIB subdir -- Red Alert (1996) game engine, AI, rendering, networking, audio, UI; Win32 platform layer under WIN32LIB/
TIBERIANDAWN
# 307 files at root + 82 in WIN32LIB subdir -- Tiberian Dawn (1995) game engine, AI, rendering, networking, audio, UI; Win32 platform layer under WIN32LIB/
CnCTDRAMapEditor
# 257 C# files -- WinForms map editor for both TD and RA (Controls, Dialogs, Model, Render, Tools, Utility, Widgets, Steamworks.NET)
#Subsections end
